# SmartClean Environment Configuration
# Copy this file to .env and fill in your values

# Security - CHANGE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-min-32-characters

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cleaning

# Redis Cache
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# S3 Storage (optional)
S3_ENABLED=false
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=smartclean
S3_PUBLIC_URL=http://localhost:9000/smartclean

# Server
HOST=0.0.0.0
PORT=80
DEBUG=false

# CDN (optional)
CDN_URL=

# Sentry (optional)
SENTRY_DSN=

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
