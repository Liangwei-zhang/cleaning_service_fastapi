# SmartClean Environment Configuration
# Copy this file to .env and fill in your values

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cleaning

# Redis Cache
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# S3 Storage (optional)
S3_ENABLED=false
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=smartclean
S3_PUBLIC_URL=http://localhost:9000/smartclean

# Server
HOST=0.0.0.0
PORT=80
DEBUG=false

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
